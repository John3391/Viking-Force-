rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para verificar se o usuário é o dono do documento (através da URL ou path)
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Função para verificar se o usuário é o treinador
    // Ajuste conforme necessário como você armazena o perfil do treinador
    function isTrainer() {
      return request.auth != null && request.auth.token.email == 'john.vasquesrodrigues@gmail.com';
    }

    // Restrição geral para todas as coleções: apenas dono ou treinador
    match /profiles/{userId} {
      allow read, write: if isOwner(userId) || isTrainer();
    }

    match /prs/{userId} {
      allow read, write: if isOwner(userId) || isTrainer();
    }

    match /trainingPrograms/{userId} {
      allow read, write: if isOwner(userId) || isTrainer();
    }

    match /trainingLogs/{userId}/logs/{logId} {
      allow read, write: if isOwner(userId) || isTrainer();
    }

    // Regras existentes mantidas para compatibilidade parcial, se necessário
    match /students/{studentEmail} {
      allow read, write: if true;
    }

    match /exercises/{exerciseId} {
      allow read, write: if request.auth != null;
    }
  }
}
