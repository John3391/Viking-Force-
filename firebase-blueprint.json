{
  "entities": {
    "StudentProfile": {
      "title": "StudentProfile",
      "description": "Viking student/athlete training, progress, and messaging profile.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the athlete"
        },
        "plan": {
          "type": "string",
          "enum": ["Mensal", "Trimestral", "Semestral", "Anual"],
          "description": "Active billing or subscription tier"
        },
        "status": {
          "type": "string",
          "enum": ["Pago", "Pendente", "Atrasado"],
          "description": "Current payment status"
        },
        "prs": {
          "type": "object",
          "description": "Personal records in Squat, Bench, and Deadlift"
        },
        "preferredTime": {
          "type": "string",
          "description": "Preferred training hours"
        },
        "prevPrs": {
          "type": "object",
          "description": "Previous personal records for evolution comparison"
        },
        "chatHistory": {
          "type": "array",
          "description": "Asynchronous chat message history between student and trainer"
        },
        "sessions": {
          "type": "array",
          "description": "Historical logged workout sessions"
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female"],
          "description": "Student gender"
        },
        "age": {
          "type": "number",
          "description": "Student age"
        },
        "bodyWeight": {
          "type": "number",
          "description": "Current body weight in kg"
        },
        "competitionDate": {
          "type": "string",
          "description": "Date of the target competition"
        }
      },
      "required": ["name", "plan", "status"]
    },
    "TrainingProgram": {
      "title": "TrainingProgram",
      "description": "The master multi-week powerlifting/strength schedule.",
      "type": "object",
      "properties": {
        "weeks": {
          "type": "object",
          "description": "Dynamic exercise schedule divided into weeks"
        }
      },
      "required": ["weeks"]
    },
    "VikingPlan": {
      "title": "VikingPlan",
      "description": "Subscription plans offered by the team.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Plan identifier"
        },
        "badge": {
          "type": "string",
          "description": "Badge icon/emoji"
        },
        "name": {
          "type": "string",
          "description": "Viking themed plan name"
        },
        "price": {
          "type": "number",
          "description": "Pricing value"
        },
        "period": {
          "type": "string",
          "description": "Billing cadence"
        },
        "description": {
          "type": "string",
          "description": "Description of benefits"
        }
      },
      "required": ["id", "name", "price"]
    },
    "DbExercise": {
      "title": "DbExercise",
      "description": "Custom or default gym exercise with instruction tips and video reference.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the exercise"
        },
        "name": {
          "type": "string",
          "description": "Name of the exercise"
        },
        "techniqueTips": {
          "type": "string",
          "description": "Tips on execution form"
        },
        "videoUrl": {
          "type": "string",
          "description": "Video tutorial URL"
        },
        "videoBase64": {
          "type": "string",
          "description": "Raw video data base64 string"
        },
        "videoFileType": {
          "type": "string",
          "description": "Video media format type"
        }
      },
      "required": ["id", "name"]
    },
    "SyncMetadata": {
      "title": "SyncMetadata",
      "description": "Timestamps of the latest global modifications to minimize read requests.",
      "type": "object",
      "properties": {
        "programUpdatedAt": {
          "type": "string"
        },
        "plansUpdatedAt": {
          "type": "string"
        },
        "exercisesUpdatedAt": {
          "type": "string"
        },
        "mobilityExercisesUpdatedAt": {
          "type": "string"
        },
        "calendarEventsUpdatedAt": {
          "type": "string"
        }
      }
    }
  },
  "firestore": {
    "students/{studentEmail}": {
      "schema": "StudentProfile",
      "description": "Student profiles storing customized schedules, logs, and communication data."
    },
    "config/program": {
      "schema": "TrainingProgram",
      "description": "The global training routine shared by recruits."
    },
    "config/metadata": {
      "schema": "SyncMetadata",
      "description": "Timestamps of the latest global modifications."
    },
    "config/plans": {
      "schema": {
        "$ref": "VikingPlan"
      },
      "description": "Global custom commercial subscription options"
    },
    "exercises/{exerciseId}": {
      "schema": "DbExercise",
      "description": "Exercises database containing standard and custom exercises."
    }
  }
}
